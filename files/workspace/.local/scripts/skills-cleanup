#!/usr/bin/env bash
set -euo pipefail

workspace="${SKILLS_WORKSPACE:-$HOME}"

case "$workspace" in
  /*) ;;
  *) workspace="$(pwd)/$workspace" ;;
esac

if [ ! -d "$workspace/.agents/skills" ]; then
  echo "skills-cleanup: $workspace does not look like a skills workspace" >&2
  exit 1
fi

# Remove provider mirrors created by `skills add --agent '*'`.
# Keep the real skill roots this repo intentionally uses.
find "$workspace" -maxdepth 1 -type d -name '.*' | while IFS= read -r dir; do
  name="$(basename "$dir")"
  case "$name" in
    .|..|.agents|.claude|.codex|.config|.hindsight|.local)
      continue
      ;;
  esac

  if [ -d "$dir/skills" ]; then
    rm -rf "$dir"
    echo "removed $dir"
  fi
done

# Drop broken skill symlinks left behind by mirror cleanup.
find "$workspace/.claude/skills" "$workspace/.codex/skills" -xtype l -print -delete 2>/dev/null || true
