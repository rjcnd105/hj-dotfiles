#!/usr/bin/env bash
#USAGE bin add-my-skill <skill-name>
#USAGE about "$SKILLIB 디렉토리의 스킬을 Claude Code에 추가"
#USAGE arg "<skill-name>" help="추가할 스킬 이름" required=#true
#USAGE complete "skill-name" run="ls $SKILLIB"

if [ -z "$1" ]; then
  echo "Usage: $(basename "$0") <skill-name>" >&2
  exit 1
fi

skill add "${SKILLIB}/$1"
