# https://ghostty.org/docs/config/keybind/reference

macos-option-as-alt = true
theme = Arcoiris
command = /Users/hj/.config/ghostty/ghostty-nix-env.sh
shell-integration = fish
font-size = 12

# Alt + n : 자동 분할 (창 비율에 맞춰 가로/세로 중 자동으로 분할)
keybind = alt+n=new_split:auto

# Alt + Shift + h, j, k, l : 지정된 방향으로 분할
keybind = alt+shift+h=new_split:left
keybind = alt+shift+j=new_split:down
keybind = alt+shift+k=new_split:up
keybind = alt+shift+l=new_split:right
keybind = alt+w=close_surface

keybind = alt+j=goto_split:down
keybind = alt+h=goto_split:left
keybind = alt+l=goto_split:right
keybind = alt+k=goto_split:up

# 한글 입력 모드에서도 동일하게 동작 (두벌식: h=ㅗ j=ㅓ k=ㅏ l=ㅣ)
keybind = alt+shift+ㅗ=new_split:left
keybind = alt+shift+ㅓ=new_split:down
keybind = alt+shift+ㅏ=new_split:up
keybind = alt+shift+ㅣ=new_split:right

keybind = alt+ㅈ=close_surface

keybind = alt+ㅓ=goto_split:down
keybind = alt+ㅗ=goto_split:left
keybind = alt+ㅣ=goto_split:right
keybind = alt+ㅏ=goto_split:up
