{
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "terminal": {
    "shell": {
      "program": "/etc/profiles/per-user/hj/bin/fish"
    }
  },
  "code_lens": "on",
  "edit_predictions": {
    "provider": "zed",
    "open_ai_compatible_api": {
      "api_url": "http://localhost:1234/v1/completions",
      "model": "NexVeridian/zeta-2-4bit",
      "prompt_format": "zeta2",

      "max_output_tokens": 128
    }
  },
  "prettier": {
    "allowed": true
  },
  "session": {
    "trust_all_worktrees": true
  },
  "document_symbols": "on",
  "semantic_tokens": "combined",
  "document_folding_ranges": "on",
  "git_panel": {
    "dock": "left",
    "tree_view": true
  },
  "agent_servers": {
    "cursor": {
      "type": "registry"
    },
    "opencode": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "agent": {
    "dock": "right",
    "inline_assistant_model": {
      "provider": "google",
      "model": "gemini-3-pro-preview",
      "enable_thinking": false
    },
    "profiles": {
      "ask": {
        "name": "Ask",
        "tools": {
          "symbol_info": true,
          "open": true,
          "diagnostics": true,
          "fetch": true,
          "list_directory": true,
          "now": true,
          "find_path": true,
          "read_file": true,
          "grep": true,
          "thinking": true
        },
        "enable_all_context_servers": false,
        "context_servers": {}
      },
      "admin": {
        "name": "admin",
        "tools": {
          "thinking": true,
          "symbol_info": true,
          "grep": true,
          "read_file": true,
          "find_path": true,
          "open": true,
          "now": true,
          "list_directory": true,
          "move_path": true,
          "edit_file": true,
          "fetch": true,
          "diagnostics": true,
          "delete_path": true,
          "create_file": true,
          "create_directory": true,
          "copy_path": true,
          "code_symbols": true,
          "batch_tool": true,
          "terminal": true
        },
        "enable_all_context_servers": false,
        "context_servers": {}
      }
    },
    "default_profile": "admin",
    "default_model": {
      "provider": "google",
      "model": "gemini-3-pro-preview"
    }
  },
  "ui_font_size": 12,
  "buffer_font_size": 12.5,
  "tab_size": 2,
  "show_completions_on_input": true,
  "remove_trailing_whitespace_on_save": true,
  "base_keymap": "JetBrains",
  "restore_on_startup": "last_session",
  "buffer_font_fallbacks": [
    "D2CodingLigature Nerd Font"
  ],
  "vim_mode": false,
  "load_direnv": "shell_hook",
  "git": {
    "inline_blame": {
      "enabled": true,
      "delay_ms": 500,
      "show_commit_summary": true
    }
  },
  "ui_font_fallbacks": [
    "D2CodingLigature Nerd Font"
  ],
  "file_types": {
    "Dockerfile": [
      "Dockerfile",
      "Dockerfile.*"
    ],
    "JSON": [
      "json",
      "jsonc",
      "*.code-snippets"
    ],
    "HEEX": [
      "heex"
    ],
    "Elixir": [
      "ex",
      "exs"
    ]
  },
  "theme": {
    "mode": "light",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Macchiato"
  },
  "auto_install_extensions": {
    "html": true,
    "dockerfile": true,
    "docker-compose": true,
    "catppuccin": true,
    "nix": true,
    "toml": true,
    "sql": true,
    "elixir": true,
    "emmet": true,
    "env": true,
    "gleam": true,
    "justfile": true,
    "haskell": true,
    "kdl": true,
    "fish": true,
    "git-firefly": true,
    "xml": true,
    "make": true,
    "Luau": true
  },
  "language_models": {
    "ollama": {
      "api_url": "http://localhost:11434",
      "available_models": [
        {
          "name": "deepseek-r1:32b",
          "display_name": "deepseek-r1:32b",
          "max_tokens": 32768333
        },
        {
          "name": "deepseek-r1:7b",
          "display_name": "deepseek-r1:7b",
          "max_tokens": 32768333
        }
      ]
    }
  },
  "file_scan_exclusions": [
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings"
  ],
  "buffer_font_features": {
    "calt": false
  },
  "project_panel": {
    "dock": "left",
    "auto_fold_dirs": false,
    "indent_size": 16,
    "git_status": true
  },
  "lsp": {
    "nixd": {
      "binary": {
        "path": "/etc/profiles/per-user/hj/bin/lspmux-nix-nixd"
      },
      "settings": {
        "formatting": {
          "command": [
            "nixfmt"
          ]
        },
        "nixpkgs": {
          "expr": "import (builtins.getFlake \"/Users/hj/dot/nix-dots\").inputs.nixpkgs { }"
        },
        "options": {
          "darwin": {
            "expr": "(builtins.getFlake \"/Users/hj/dot/nix-dots\").darwinConfigurations.workspace_hj.options"
          },
          "home-manager": {
            "expr": "(builtins.getFlake \"/Users/hj/dot/nix-dots\").darwinConfigurations.workspace_hj.options.home-manager.users.type.getSubOptions []"
          }
        },
        "diagnostic": {
          "suppress": [
            "sema-extra-with"
          ]
        }
      }
    },
    "elixir-ls": {
      "binary": {
        "path": "/etc/profiles/per-user/hj/bin/lspmux-mise-elixir-ls"
      },
      "settings": {
        "dialyzerEnabled": true,
        "incrementalDialyzer": true,
        "suggestSpecs": true,
        "signatureHelp": true,
        "fetchDeps": true,
        "signatureAfterComplete": true,
        "enableHEExFormatter": true
      }
    },
    "expert": {
      "binary": {
        "path": "/etc/profiles/per-user/hj/bin/lspmux-mise-expert"
      },
      "settings": {
        "workspaceSymbols": {
          "minQueryLength": 0
        }
      }
    },
    "rust-analyzer": {
      "binary": {
        "path": "/etc/profiles/per-user/hj/bin/lspmux-mise-rust-analyzer"
      }
    },
    "vtsls": {
      "binary": {
        "path": "/etc/profiles/per-user/hj/bin/lspmux-mise-vtsls"
      }
    },
    "vscode-html-language-server": {
      "binary": {
        "path": "/etc/profiles/per-user/hj/bin/lspmux-mise-html-language-server"
      }
    },
    "css-language-server": {
      "binary": {
        "path": "/etc/profiles/per-user/hj/bin/lspmux-mise-css-language-server"
      }
    },
    "json-language-server": {
      "binary": {
        "path": "/etc/profiles/per-user/hj/bin/lspmux-mise-json-language-server"
      }
    },
    "markdown-language-server": {
      "binary": {
        "path": "/etc/profiles/per-user/hj/bin/lspmux-mise-markdown-language-server"
      }
    },
    "yaml-language-server": {
      "binary": {
        "path": "/etc/profiles/per-user/hj/bin/lspmux-mise-yaml-language-server"
      }
    },
    "taplo": {
      "binary": {
        "path": "/etc/profiles/per-user/hj/bin/lspmux-mise-taplo"
      }
    },
    "biome": {
      "binary": {
        "path": "/etc/profiles/per-user/hj/bin/lspmux-mise-biome"
      }
    },
    "emmet-language-server": {
      "binary": {
        "path": "/etc/profiles/per-user/hj/bin/lspmux-mise-emmet-language-server"
      },
      "settings": {
        "emmet": {
          "includeLanguages": {
            "elixir": "html",
            "heex": "html",
            "phoenix-heex": "html"
          },
          "showExpandedAbbreviation": "always",
          "showSuggestionsAsSnippets": true
        }
      }
    },
    "eslint": {
      "binary": {
        "path": "/etc/profiles/per-user/hj/bin/lspmux-mise-eslint-language-server"
      },
      "settings": {
        "codeActionOnSave": {
          "rules": [
            "import/order"
          ]
        }
      }
    },
    "gopls": {
      "binary": {
        "path": "/etc/profiles/per-user/hj/bin/lspmux-mise-gopls"
      },
      "initialization_options": {
        "usePlaceholders": true,
        "completeUnimported": true,
        "staticcheck": true,
        "formatting": {
          "gofumpt": true
        },
        "analyses": {
          "unusedparams": true,
          "unusedwrite": true,
          "shadow": true,
          "nilness": true,
          "useany": true
        },
        "hints": {
          "assignVariableTypes": true,
          "compositeLiteralFields": true,
          "compositeLiteralTypes": true,
          "constantValues": true,
          "functionTypeParameters": true,
          "parameterNames": true,
          "rangeVariableTypes": true
        },
        "codelenses": {
          "generate": true,
          "test": true,
          "tidy": true,
          "upgrade_dependency": true,
          "vendor": true
        },
        "semanticTokens": true,
        "vulncheck": "Imports"
      }
    },
    "tailwindcss-language-server": {
      "binary": {
        "path": "/etc/profiles/per-user/hj/bin/lspmux-mise-tailwindcss-language-server"
      },
      "settings": {
        "classFunctions": [
          "tw",
          "clsx",
          "cx",
          "tva",
          "twMerge",
          "cva",
          "cn"
        ],
        "classAttributes": [
          "className",
          "class"
        ],
        "emmetCompletions": true,
        "experimental": {
            "classRegex": ["[cls|cn|className]\\s\\:\\=\\s\"([^\"]*)"]
          }
      }
    }
  },
  "languages": {
    "JavaScript": {
      "formatter": null,
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "TypeScript": {
      "formatter": null,
      "language_servers": ["vtsls"],
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },

    "TSX": {
      "formatter": null,
      "language_servers": [ "vtsls", "tailwindcss-language-server"],
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "JSON": {
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      }
    },
    "JSONC": {
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      }
    },
    "CSS": {
      "language_servers": [
        "css-language-server",
        "tailwindcss-language-server"
      ],
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      }
    },
    "Elixir": {
      "formatter": {
        "external": {
          "command": "mix",
          "arguments": [
            "format",
            "--stdin-filename",
            "{buffer_path}",
            "-"
          ]
        }
      },
      "show_edit_predictions": true,
      "show_whitespaces": "selection",
      "language_servers": [
        "elixir-ls",
        "expert",
        "!next-ls",
        "!lexical",
        "vscode-html-language-server",
        "tailwindcss-language-server"
      ],
      "format_on_save": "on"
    },
    "HEEx": {
      "formatter": {
        "external": {
          "command": "mix",
          "arguments": [
            "format",
            "--stdin-filename",
            "{buffer_path}",
            "-"
          ]
        }
      },
      "show_edit_predictions": true,
      "show_whitespaces": "selection",
      "format_on_save": "on",
      "language_servers": [
        "elixir-ls",
        "expert",
        "!next-ls",
        "!lexical",
        "vscode-html-language-server",
        "tailwindcss-language-server",
        "emmet-language-server"
      ]
    },
    "Go": {
      "language_servers": ["gopls"],
      "formatter": {
        "language_server": {
          "name": "gopls"
        }
      },
      "code_actions_on_format": {
        "source.organizeImports": true
      },
      "format_on_save": "on",
      "tab_size": 4,
      "hard_tabs": true,
      "show_edit_predictions": true,
      "show_whitespaces": "selection"
    },
    "Nix": {
      "language_servers": [
        "nixd",
        "!nil"
      ],
      "formatter": {
        "language_server": {
          "name": "nixd"
        }
      },
      "format_on_save": "on",
      "show_edit_predictions": true,
      "show_whitespaces": "selection"
    }
  },
  "context_servers": {
    "chrome-devtools-mcp-zed": {
      "enabled": true,
      "remote": false,
      "settings": {
        "browser_url": null,
        "ws_endpoint": null,
        "ws_headers": null,
        "auto_connect": true,
        "channel": null,
        "headless": null,
        "isolated": null,
        "user_data_dir": null,
        "viewport": null,
        "executable_path": null,
        "chrome_arg": [],
        "proxy_server": null,
        "accept_insecure_certs": null,
        "category_emulation": null,
        "category_performance": null,
        "category_network": null,
        "log_file": null,
        "extra_args": []
      }
    },
    "mcp-server-github": {
      "enabled": true,
      "remote": false,
      "settings": {}
    },
    "mcp-server-exa-search": {
      "enabled": true,
      "remote": false,
      "settings": {
        "exa_api_key": "3c524b3a-c4d4-4c8a-8348-b7018f3ce1fd"
      }
    },
    "postgres-context-server": {
      "enabled": true,
      "remote": false,
      "settings": {}
    }
  }
}
