{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(env)",
      "Bash(gh *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(grep *)",
      "Bash(grep -r *)",
      "Bash(jj diff *)",
      "Bash(jj log *)",
      "Bash(jj show *)",
      "Bash(jj status)",
      "Bash(just *)",
      "Bash(ls *)",
      "Bash(mise *)",
      "Bash(mkdir *)",
      "Bash(nix eval *)",
      "Bash(nix flake *)",
      "Bash(nixfmt *)",
      "Bash(node *)",
      "Bash(which *)",
      "WebFetch",
      "WebSearch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/hj/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "context7@claude-plugins-official": false,
    "compound-engineering@compound-engineering-plugin": true,
    "last30days@last30days-skill": true,
    "harness@harness-marketplace": true,
    "hindsight-memory@hindsight": true,
    "context-engineering@context-engineering-marketplace": true,
    "frontend-design@claude-plugins-official": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "compound-engineering-plugin": {
      "source": {
        "source": "github",
        "repo": "EveryInc/compound-engineering-plugin"
      }
    },
    "last30days-skill": {
      "source": {
        "source": "github",
        "repo": "mvanhorn/last30days-skill"
      }
    },
    "harness-marketplace": {
      "source": {
        "source": "github",
        "repo": "revfactory/harness"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "hindsight": {
      "source": {
        "source": "github",
        "repo": "vectorize-io/hindsight"
      }
    },
    "context-engineering-marketplace": {
      "source": {
        "source": "github",
        "repo": "muratcankoylan/Agent-Skills-for-Context-Engineering"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "claude-code-lsps": {
      "source": {
        "source": "github",
        "repo": "boostvolt/claude-code-lsps"
      }
    }
  },
  "language": "Korean",
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true
}
