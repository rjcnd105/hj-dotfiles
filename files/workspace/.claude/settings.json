{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(env)",
      "Bash(gh *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(grep *)",
      "Bash(grep -r *)",
      "Bash(jj diff *)",
      "Bash(jj log *)",
      "Bash(jj show *)",
      "Bash(jj status)",
      "Bash(just *)",
      "Bash(ls *)",
      "Bash(mise *)",
      "Bash(mkdir *)",
      "Bash(nix eval *)",
      "Bash(nix flake *)",
      "Bash(nixfmt *)",
      "Bash(node *)",
      "Bash(which *)",
      "WebFetch",
      "WebSearch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/hj/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/hj/.claude/hooks/jj-vcs-context.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "context7@claude-plugins-official": false,
    "compound-engineering@compound-engineering-plugin": true,
    "hindsight-memory@hindsight": true,
    "frontend-design@claude-plugins-official": true,
    "caveman@caveman": true,
    "reflexion@context-engineering-kit": false,
    "sdd@context-engineering-kit": false,
    "sadd@context-engineering-kit": false,
    "ddd@context-engineering-kit": true,
    "playwright@claude-plugins-official": true,
    "serena@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "compound-engineering-plugin": {
      "source": {
        "source": "github",
        "repo": "EveryInc/compound-engineering-plugin"
      }
    },
    "harness-marketplace": {
      "source": {
        "source": "github",
        "repo": "revfactory/harness"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "hindsight": {
      "source": {
        "source": "github",
        "repo": "vectorize-io/hindsight"
      }
    },
    "context-engineering-marketplace": {
      "source": {
        "source": "github",
        "repo": "muratcankoylan/Agent-Skills-for-Context-Engineering"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "claude-code-lsps": {
      "source": {
        "source": "github",
        "repo": "boostvolt/claude-code-lsps"
      }
    },
    "context-engineering-kit": {
      "source": {
        "source": "github",
        "repo": "NeoLabHQ/context-engineering-kit"
      }
    }
  },
  "language": "Korean",
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
